{%- comment -%}
  Grid card for variant-list collections.
  Shows product image, title, compact variant list, from-price, stock.
{%- endcomment -%}

{%- liquid
  assign variant_count = product.variants.size
  assign has_stock = false
  assign has_outlet = false
  assign outlet_count = 0
  for v in product.variants
    if v.metafields.custom.stock_status == 'I lager'
      assign has_stock = true
    endif
    if v.metafields.custom.outlet
      assign has_outlet = true
      assign outlet_count = outlet_count | plus: 1
    endif
  endfor
  assign is_fully_outlet = false
  if outlet_count == variant_count
    assign is_fully_outlet = true
  endif

  assign featured_media = product.featured_media
  assign image_ratio = settings.pcard_image_ratio | default: '1'
  if image_ratio == 'adapt' and featured_media != blank
    assign image_ratio = featured_media.aspect_ratio
  elsif image_ratio == 'adapt'
    assign image_ratio = '1'
  endif

  assign unique_id = section_id | append: '-' | append: product.id
  assign max_visible = 1

  assign loading = 'lazy'
  assign fetchpriority = 'low'
  if section_index < 3 and index == 1
    assign loading = 'eager'
    assign fetchpriority = 'high'
  endif
-%}

<div class="cv-grid-card product-card product-card-style-{{ settings.pcard_style }}{% if settings.pcard_style == 'card' %} color-{{ settings.pcard_color_scheme }}{% endif %}" data-product-url="{{ product.url }}">
  <div class="cv-grid-card__wrapper h-full">
    <a href="{{ product.url }}" class="cv-grid-card__link" aria-label="{{ product.title | escape }}">
      <div class="cv-grid-card__image-wrap color-{{ settings.pcard_overlay_color_scheme }} bg-none">
        {%- if has_outlet -%}
          <span class="cv-grid-card__outlet-badge">{%- if is_fully_outlet -%}Outlet{%- else -%}Outlet-alternativ{%- endif -%}</span>
        {%- endif -%}
        {%- if featured_media -%}
          <div class="media-wrapper cv-grid-card__image" style="--aspect-ratio: {{ image_ratio }}">
            {{ featured_media | image_url: width: featured_media.width | image_tag:
              loading: loading,
              fetchpriority: fetchpriority,
              class: 'motion-reduce cv-grid-card__img',
              widths: '200, 400, 535, 710, 900',
              sizes: '(max-width: 767px) 50vw, (max-width: 1279px) 33vw, 25vw',
              is: 'image-lazy'
            }}
          </div>
        {%- else -%}
          <div class="cv-grid-card__image" style="--aspect-ratio: {{ image_ratio }}">
            <img
              src="https://cdn.shopify.com/s/files/1/0908/2804/6670/files/square-bildkommer_41fdbdd7-eb36-462b-b879-5ae871f39315.jpg?v=1754924924"
              alt="Default product image"
              width="600"
              height="600"
              class="w-full h-auto"
            >
          </div>
        {%- endif -%}
      </div>
    </a>
    <div class="cv-grid-card__info text-{{ settings.pcard_content_alignment | default: 'left' }}">
      <h3 class="cv-grid-card__title text-pcard-title">
        <a class="reversed-link block" href="{{ product.url }}">
          <span class="reversed-link__text">{{ product.title }}</span>
        </a>
      </h3>

      <div class="cv-grid-card__meta text-sm">
        <span class="cv-grid-card__stock {% if has_stock %}cv-grid-card__stock--in{% else %}cv-grid-card__stock--out{% endif %} customer-only-inline">
          <span class="stock-dot {% if has_stock %}stock-dot--in-stock{% else %}stock-dot--out-of-stock{% endif %}"></span>
          {%- if has_stock -%}I lager{%- else -%}Beställningsvara{%- endif -%}
        </span>
        {%- if variant_count > 1 -%}<span class="cv-grid-card__count customer-only-inline">{{ variant_count }} varianter</span>{%- endif -%}
        <span class="cv-grid-card__login-msg guest-only-content text-sm">Logga in för att handla</span>
      </div>

      <div class="cv-grid-card__variants-list">
        {%- for variant in product.variants -%}
          {%- unless variant.option1 == 'Default Title' -%}
          <a href="{{ product.url }}?variant={{ variant.id }}" class="cv-grid-card__variant-row text-sm{% if forloop.index > max_visible %} cv-grid-card__variant-row--extra{% endif %}">
            <span class="cv-grid-card__variant-option">{{ variant.option1 }}{%- if variant.option2 %} · {{ variant.option2 }}{%- endif -%}{%- if variant.option3 %} · {{ variant.option3 }}{%- endif -%}</span>
            {%- if variant.metafields.custom.outlet -%}<span class="cv-grid-card__variant-outlet">Outlet</span>{%- endif -%}
          </a>
          {%- endunless -%}
        {%- endfor -%}
        {%- if variant_count > max_visible -%}
          {%- assign extra_count = variant_count | minus: max_visible -%}
          <span class="cv-grid-card__more text-sm" role="button" tabindex="0" data-extra-count="{{ extra_count }}">
            <span class="cv-grid-card__more-show">+ {{ extra_count }} {%- if extra_count == 1 %} till variant{%- else %} fler varianter{%- endif -%}</span>
            <span class="cv-grid-card__more-hide" hidden>visa färre</span>
          </span>
        {%- endif -%}
      </div>

      <div class="cv-grid-card__price customer-only-content{% if is_fully_outlet %} cv-grid-card__price--outlet{% endif %}" data-from-price-grid="{{ unique_id }}">
        {%- if variant_count > 1 -%}<span class="cv-grid-card__price-label text-sm">Från</span>{%- endif -%}
        <span class="cv-grid-card__price-value">-</span>
        <span class="cv-grid-card__price-unit text-sm"></span>
      </div>
    </div>
  </div>
</div>

<style>
  .cv-grid-card {
    display: grid;
    grid-row: span 5;
    grid-template-rows: subgrid;
    border-radius: 1rem;
    overflow: hidden;
  }

  .cv-grid-card__wrapper {
    display: grid;
    grid-row: span 5;
    grid-template-rows: subgrid;
    background: #fff;
    border-radius: 1rem;
    overflow: hidden;
    transition: box-shadow 0.15s;
  }

  .cv-grid-card__wrapper:hover {
    box-shadow: 0 0.25rem 1rem rgba(0,0,0,0.08);
  }

  .cv-grid-card__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .cv-grid-card__image-wrap {
    position: relative;
    overflow: hidden;
    padding: 1.25rem 1.25rem 0.25rem;
  }

  .cv-grid-card__image {
    position: relative;
    overflow: hidden;
    background: rgb(var(--color-secondary-background));
    border-radius: 0.5rem;
  }

  .cv-grid-card__image img,
  .cv-grid-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .cv-grid-card__wrapper:hover .cv-grid-card__img,
  .cv-grid-card__wrapper:hover .cv-grid-card__image img {
    transform: scale(1.05);
  }

  .cv-grid-card__info {
    padding: 0.5rem 1.25rem 1.5rem;
    display: grid;
    grid-row: span 4;
    grid-template-rows: subgrid;
  }

  .cv-grid-card__title {
    margin: 0;
    position: relative;
  }

  /* Variant list */
  .cv-grid-card__variants-list {
    display: flex;
    flex-direction: column;
    gap: 0.1875rem;
    align-self: start;
    position: relative;
    z-index: 1;
  }

  .cv-grid-card__variant-row {
    display: flex;
    align-items: baseline;
    gap: 0.375rem;
    color: var(--color-foreground-lighten-40);
    line-height: 1.4;
    background: rgb(var(--color-secondary-background));
    padding: 0.3rem 0.625rem;
    border-radius: 0.375rem;
    text-decoration: none;
    transition: background-color 0.1s;
    position: relative;
    z-index: 1;
  }

  .cv-grid-card__variant-row:hover {
    background: rgb(var(--color-border));
  }

  .cv-grid-card__variant-sku {
    font-family: var(--font-body-family, monospace);
    flex-shrink: 0;
  }

  .cv-grid-card__variant-sep {
    color: var(--color-foreground-lighten-60);
  }

  .cv-grid-card__variant-option {
    color: rgb(var(--color-foreground));
  }

  .cv-grid-card__variant-outlet {
    color: rgb(var(--color-primary));
    margin-left: auto;
    font-weight: 600;
  }

  .cv-grid-card__variant-row--extra {
    display: none;
  }

  .cv-grid-card__variants-list.is-expanded .cv-grid-card__variant-row--extra {
    display: flex;
  }

  .cv-grid-card__more {
    color: rgb(var(--color-foreground));
    background: none;
    border: none;
    padding: 0.375rem 0 0;
    cursor: pointer;
    font-family: inherit;
    text-align: left;
    align-self: flex-start;
    font-weight: 600;
    position: relative;
    z-index: 1;
  }

  .cv-grid-card__more:hover {
    text-decoration: underline;
  }

  .cv-grid-card__price {
    display: flex;
    align-items: baseline;
    gap: 0.375rem;
    align-self: end;
    padding-top: 0.5rem;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .cv-grid-card__price.is-loaded { opacity: 1; }

  .cv-grid-card__price-label {
    color: var(--color-foreground-lighten-40);
  }

  .cv-grid-card__price-value {
    font-weight: 600;
    font-size: calc(var(--font-pcard-title-size, 1.1rem) * 1.4);
    color: rgb(var(--color-foreground));
  }

  .cv-grid-card__price-unit {
    color: var(--color-foreground-lighten-40);
  }

  .cv-grid-card__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.375rem 0.5rem;
    align-self: start;
  }

  .cv-grid-card__meta > span + span::before {
    content: '\00b7';
    margin-right: 0.5rem;
    color: var(--color-foreground-lighten-60);
  }

  .cv-grid-card__meta > .guest-only-content::before { content: none !important; }

  .cv-grid-card__stock--in { color: #0d8756; }
  .cv-grid-card__stock--out { color: #d97706; }
  .cv-grid-card__count { color: var(--color-foreground-lighten-40); }

  .cv-grid-card__price--outlet .cv-grid-card__price-value {
    color: rgb(var(--color-primary));
  }

  .cv-grid-card__outlet-badge {
    position: absolute;
    top: 2.25rem;
    left: 2.25rem;
    background: rgb(196, 48, 28);
    color: #fff;
    padding: 0.3rem 0.625rem;
    border-radius: 0.375rem;
    font-weight: 500;
    z-index: 1;
  }

  @media (max-width: 767px) {
    .cv-grid-card__title {
      font-size: 16px !important;
    }
    .cv-grid-card__image-wrap {
      padding: 0.75rem 0.75rem 0.25rem;
    }
    .cv-grid-card {
      row-gap: 0.5rem !important;
    }
    .cv-grid-card__info {
      padding: 0.375rem 0.75rem 0.75rem;
    }
    .cv-grid-card__price-value {
      font-size: 22px !important;
    }
    .cv-grid-card__outlet-badge {
      font-size: 16px !important;
    }
  }
</style>

<script>
if (!window.__cvGridCardInit) {
  window.__cvGridCardInit = true;
  document.addEventListener('click', function(e) {
    /* Expand / collapse variants */
    var moreBtn = e.target.closest('.cv-grid-card__more');
    if (moreBtn) {
      e.preventDefault();
      e.stopPropagation();
      var list = moreBtn.closest('.cv-grid-card__variants-list');
      if (!list) return;
      var expanded = list.classList.toggle('is-expanded');
      var showEl = moreBtn.querySelector('.cv-grid-card__more-show');
      var hideEl = moreBtn.querySelector('.cv-grid-card__more-hide');
      if (showEl) showEl.hidden = expanded;
      if (hideEl) hideEl.hidden = !expanded;
      return;
    }
  });
}
</script>
