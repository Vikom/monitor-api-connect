{%- if customer and customer.metafields.custom.is_sales_rep -%}
<div id="SalesRepPanel" class="sales-rep-panel">
  <div class="sales-rep-panel__bar" id="SalesRepBar" style="display:none;">
    <span class="sales-rep-panel__info">Kundvy: <strong id="SalesRepActiveId"></strong></span>
    <div class="sales-rep-panel__actions">
      <button class="sales-rep-panel__action" id="SalesRepChange" type="button">Byt kund</button>
      <button class="sales-rep-panel__action" id="SalesRepClear" type="button">Avsluta</button>
    </div>
  </div>
  <div class="sales-rep-panel__input" id="SalesRepInput">
    <span class="sales-rep-panel__info">Visa priser för kund</span>
    <input type="text" id="SalesRepMonitorId" class="sales-rep-panel__field" placeholder="Monitor-ID" autocomplete="off">
    <button class="sales-rep-panel__action" id="SalesRepActivate" type="button">Aktivera</button>
  </div>
</div>

<style>
  .sales-rep-panel {
    position: sticky;
    top: 0;
    z-index: 9999;
    font-size: 11px;
    line-height: 1;
  }

  .sales-rep-panel__bar,
  .sales-rep-panel__input {
    background: rgb(29, 52, 154);
    color: #e5e5e5;
    padding: 0.6rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .sales-rep-panel__info {
    flex: 1;
    white-space: nowrap;
    color: #a3a3a3;
  }

  .sales-rep-panel__info strong {
    color: #fff;
    font-weight: 500;
  }

  .sales-rep-panel__actions {
    display: flex;
    gap: 0.375rem;
  }

  .sales-rep-panel__action {
    background: rgba(0,0,0,0.25) !important;
    color: #e5e5e5 !important;
    border: none !important;
    padding: 0 0.875rem !important;
    border-radius: 0.375rem !important;
    cursor: pointer;
    font-size: 11px !important;
    line-height: 1 !important;
    height: 26px !important;
    white-space: nowrap;
    min-height: unset !important;
    text-transform: none !important;
    letter-spacing: 0 !important;
  }

  .sales-rep-panel__action:hover {
    background: rgba(0,0,0,0.4) !important;
    color: #fff !important;
  }

  .sales-rep-panel__field {
    background: rgba(0,0,0,0.25);
    color: #fff;
    border: none;
    padding: 0 0.5rem 0 0.75rem;
    border-radius: 0.25rem;
    font-size: 11px;
    font-family: inherit;
    line-height: 1;
    height: 26px;
    width: 12rem;
    outline: none;
  }

  .sales-rep-panel__field::placeholder {
    color: rgba(255,255,255,0.45);
  }

  .sales-rep-panel__field:focus {
    background: rgba(0,0,0,0.35);
  }
</style>

<script>
(function() {
  var input = document.getElementById('SalesRepMonitorId');
  var activateBtn = document.getElementById('SalesRepActivate');
  var changeBtn = document.getElementById('SalesRepChange');
  var clearBtn = document.getElementById('SalesRepClear');
  var bar = document.getElementById('SalesRepBar');
  var inputSection = document.getElementById('SalesRepInput');
  var activeIdEl = document.getElementById('SalesRepActiveId');

  // Check if already active
  var existing = null;
  try { existing = JSON.parse(sessionStorage.getItem('salesRepCustomer')); } catch(e) {}

  if (existing && existing.monitorId) {
    bar.style.display = 'flex';
    inputSection.style.display = 'none';
    activeIdEl.textContent = existing.monitorId;
  }

  activateBtn.addEventListener('click', function() {
    var monitorId = input.value.trim();
    if (!monitorId) return;
    sessionStorage.setItem('salesRepCustomer', JSON.stringify({ monitorId: monitorId }));
    window.location.reload();
  });

  input.addEventListener('keydown', function(e) {
    if (e.key === 'Enter') activateBtn.click();
  });

  changeBtn.addEventListener('click', function() {
    bar.style.display = 'none';
    inputSection.style.display = 'flex';
    input.value = '';
    input.focus();
  });

  clearBtn.addEventListener('click', function() {
    sessionStorage.removeItem('salesRepCustomer');
    window.location.reload();
  });
})();
</script>
{%- endif -%}
