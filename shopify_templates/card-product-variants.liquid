{%- comment -%}
  Renders a product card in list format with expandable variant table.
  Shows product image + name, with a foldout table of all variants
  including synced stock status, dynamic price, quantity selector and add-to-cart.

  Accepts:
  - product: {Object} Product Liquid object
  - section_id: {String} Section ID
  - section_index: {Number} Section index for lazy loading

  Usage:
  {% render 'card-product-variants', product: product, section_id: section.id, section_index: 2 %}
{%- endcomment -%}

{%- liquid
  assign variant_count = product.variants.size
  assign has_stock = false
  assign has_outlet = false
  assign outlet_count = 0
  for v in product.variants
    if v.metafields.custom.stock_status == 'I lager'
      assign has_stock = true
    endif
    if v.metafields.custom.outlet
      assign has_outlet = true
      assign outlet_count = outlet_count | plus: 1
    endif
  endfor
  assign is_fully_outlet = false
  if outlet_count == variant_count
    assign is_fully_outlet = true
  endif

  if is_outlet_collection
    assign variant_count = outlet_count
    assign is_fully_outlet = true
  endif

  assign featured_media = product.featured_media
  assign image_ratio = '1'
  if featured_media != blank
    assign image_ratio = featured_media.aspect_ratio
  endif

  assign unique_id = section_id | append: '-' | append: product.id
-%}

<div class="card-variants" id="CardVariants-{{ unique_id }}">
  <div class="card-variants__header">
    <div class="card-variants__image">
      <a href="{{ product.url }}" aria-label="{{ product.title | escape }}">
        {%- if featured_media -%}
          <div class="media-wrapper" style="--aspect-ratio: {{ image_ratio }}">
            {{ featured_media | image_url: width: 200 | image_tag:
              loading: 'lazy',
              widths: '100, 200',
              sizes: '100px',
              class: 'card-variants__img'
            }}
          </div>
        {%- else -%}
          <div class="media-wrapper" style="--aspect-ratio: 1">
            <img
              src="https://cdn.shopify.com/s/files/1/0908/2804/6670/files/square-bildkommer_41fdbdd7-eb36-462b-b879-5ae871f39315.jpg?v=1754924924"
              alt="Default product image"
              width="200"
              height="200"
              class="card-variants__img"
            >
          </div>
        {%- endif -%}
      </a>
    </div>
    <div class="card-variants__info">
      <h3 class="card-variants__title text-pcard-title">
        <a href="{{ product.url }}">{{ product.title }}</a>
      </h3>
      <div class="card-variants__meta text-sm">
        {%- if variant_count == 1 and product.variants.first.option1 != 'Default Title' -%}
          <span class="card-variants__variant-name">{{ product.variants.first.option1 }}{%- if product.variants.first.option2 %} · {{ product.variants.first.option2 }}{%- endif -%}{%- if product.variants.first.option3 %} · {{ product.variants.first.option3 }}{%- endif -%}</span>
        {%- elsif variant_count > 1 -%}
          <span class="card-variants__variant-count">{{ variant_count }} varianter</span>
        {%- endif -%}
        {%- if product.metafields.custom.fsc_pefc != blank -%}
          <span class="card-variants__tag text-sm">{{ product.metafields.custom.fsc_pefc }}</span>
        {%- endif -%}
        <span class="card-variants__stock-summary {% if has_stock %}in-stock{% else %}out-of-stock{% endif %} customer-only-inline">
          {%- if has_stock -%}I lager{%- else -%}Beställningsvara{%- endif -%}
        </span>
        {%- if is_outlet_collection -%}
          <span class="card-variants__outlet-badge">Outlet</span>
        {%- elsif has_outlet -%}
          <span class="card-variants__outlet-badge">{%- if is_fully_outlet -%}Outlet{%- else -%}Outlet-alternativ{%- endif -%}</span>
        {%- endif -%}
      </div>
    </div>
    <div class="card-variants__actions">
      <div class="card-variants__from-price-wrap customer-only-content{% if is_fully_outlet %} card-variants__from-price-wrap--outlet{% endif %}" data-from-price-for="{{ unique_id }}">
        {%- if variant_count > 1 -%}<span class="card-variants__from-label text-sm">Från</span>{%- endif -%}
        <span class="card-variants__from-value">-</span>
        <span class="card-variants__from-unit text-sm"></span>
      </div>
      <button
        class="btn btn--secondary card-variants__toggle"
        aria-expanded="false"
        aria-controls="VariantTable-{{ unique_id }}"
        data-toggle-for="CardVariants-{{ unique_id }}"
      >
        <span class="btn__text flex gap-2 items-center">
          <span class="card-variants__toggle-text">{%- if variant_count == 1 -%}Visa detaljer{%- else -%}{{ variant_count }} varianter{%- endif -%}</span>
          <span class="card-variants__toggle-icon">
            <svg width="16" height="16" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </span>
      </button>
    </div>
  </div>

  <div class="card-variants__table-wrapper" id="VariantTable-{{ unique_id }}" hidden>
    <table class="card-variants__table">
      <thead>
        <tr>
          <th>Art.nr</th>
          {%- for option in product.options -%}
            <th>{{ option }}</th>
          {%- endfor -%}
          <th class="customer-only-table-cell">Lager</th>
          <th class="card-variants__th-price customer-only-table-cell">Pris ex. moms</th>
          <th class="card-variants__th-buy customer-only-table-cell"></th>
          <th class="guest-only-table-cell"></th>
        </tr>
      </thead>
      <tbody class="text-sm">
        {%- for variant in product.variants -%}
          {%- assign is_outlet_variant = variant.metafields.custom.outlet -%}
          {%- if is_outlet_collection and is_outlet_variant != true -%}{%- continue -%}{%- endif -%}
          <tr class="card-variants__row{% if is_outlet_variant %} card-variants__row--outlet{% endif %}" data-variant-id="{{ variant.id }}" data-monitor-id="{{ variant.metafields.custom.monitor_id }}" data-unit-id="{{ variant.metafields.custom.unitid }}" data-unit="{{ variant.metafields.custom.standard_unit | default: 'st' }}">
            <td class="card-variants__artno" data-label="Art.nr">
              <a href="{{ product.url }}?variant={{ variant.id }}">{{ variant.sku | default: variant.metafields.custom.monitor_id | default: '-' }}</a>
            </td>
            {%- for i in (1..product.options.size) -%}
              <td class="card-variants__option" data-label="{{ product.options[forloop.index0] }}">
                <a href="{{ product.url }}?variant={{ variant.id }}">
                  {%- case i -%}
                    {%- when 1 -%}{%- if variant.option1 == 'Default Title' -%}-{%- else -%}{{ variant.option1 }}{%- endif -%}
                    {%- when 2 -%}{{ variant.option2 }}
                    {%- when 3 -%}{{ variant.option3 }}
                  {%- endcase -%}
                </a>
              </td>
            {%- endfor -%}
            {%- liquid
              assign stock_status_meta = variant.metafields.custom.stock_status
            -%}
            <td class="card-variants__stock customer-only-table-cell" data-label="Lager"
              data-stock-variant-id="{{ variant.id }}"
              data-stock-monitor-id="{{ variant.metafields.custom.monitor_id }}"
              data-stock-synced="{{ stock_status_meta | default: '' }}"
              data-stock-available="{{ variant.available }}"
            >
              <span class="card-variants__stock-initial">
                <span class="stock-dot stock-dot--loading"></span> Hämtar lager...
              </span>
            </td>
            {%- liquid
              assign v_standard_unit = variant.metafields.custom.standard_unit | default: 'st'
            -%}
            <td class="card-variants__price f-price f-price--loading customer-only-table-cell" data-label="Pris"
              data-variant-id="{{ variant.id }}"
              data-variant-monitor-id="{{ variant.metafields.custom.monitor_id }}"
              data-variant-unit-id="{{ variant.metafields.custom.unitid }}"
            >
              <span class="card-variants__price-value">-</span><span class="card-variants__price-unit text-sm">/{{ v_standard_unit }}</span>
            </td>
            <td class="card-variants__buy-cell customer-only-table-cell">
              <form method="post" action="/cart/add" id="variant-form-{{ unique_id }}-{{ variant.id }}" class="card-variants__form" is="product-form" data-hide-errors="true">
                <input type="hidden" name="id" value="{{ variant.id }}">
                <quantity-input class="quantity">
                  <button type="button" name="minus" class="quantity__button" aria-label="Minska antal">
                    <svg width="16" height="16" viewBox="0 0 15 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M2.6875 7H12.3125" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                  <input
                    class="quantity__input"
                    type="number"
                    name="quantity"
                    value="1"
                    min="1"
                    step="1"
                    size="3"
                    inputmode="numeric"
                    autocomplete="off"
                    aria-label="Antal"
                  >
                  <button type="button" name="plus" class="quantity__button" aria-label="Öka antal">
                    <svg width="16" height="16" viewBox="0 0 15 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M2.6875 7H12.3125" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M7.5 2.1875V11.8125" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                </quantity-input>
                <span class="quantity-unit">{{ v_standard_unit }}</span>
                <button
                  type="submit"
                  class="btn btn--primary card-variants__add-btn"
                >
                  Lägg till
                </button>
              </form>
            </td>
            <td class="card-variants__guest-cell guest-only-table-cell text-sm">Logga in för att handla</td>
          </tr>
        {%- endfor -%}
      </tbody>
    </table>
  </div>
</div>

<style>
  /* ========== Design tokens ========== */
  .card-variants {
    --cv-pad: 1.25rem;
    --cv-col-artno: 6.5rem;
    --cv-col-stock: 12rem;
    --cv-col-price: 14rem;
    --cv-col-actions: 18rem;
    --cv-col-gap: 1rem;
    --cv-img-h: 50px;
    --cv-img-ratio: 1 / 1;
    --cv-btn-height: 2.6rem;

    background: #fff;
    border-radius: 1rem;
    width: 100%;
    overflow: visible;
    transition: box-shadow 0.15s;
  }

  .card-variants:hover {
    box-shadow: inset 0 0 0 1px rgb(var(--color-border));
  }

  .card-variants.is-expanded,
  .card-variants:has(.card-variants__toggle[aria-expanded="true"]) {
    box-shadow: inset 0 0 0 1px rgb(var(--color-foreground)) !important;
  }

  /* ========== Header ========== */
  .card-variants__header {
    display: flex;
    align-items: center;
    padding: var(--cv-pad);
    gap: 0;
  }

  .card-variants__image {
    flex: 0 0 auto;
    height: var(--cv-img-h);
    aspect-ratio: var(--cv-img-ratio);
  }

  .card-variants__image .media-wrapper {
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: 0.375rem;
    background: rgb(var(--color-secondary-background));
  }

  .card-variants__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-variants__info {
    flex: 1 1 0%;
    min-width: 0;
    padding: 0 var(--cv-col-gap) 0 calc(2 * var(--cv-col-gap));
  }

  .card-variants__title { margin: 0 0 0.2rem; font-size: 16px; }
  .card-variants__title a { color: inherit; text-decoration: none; }
  .card-variants__title a:hover { text-decoration: underline; }

  .card-variants__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.375rem 0.5rem;
  }

  .card-variants__meta > span + span::before {
    content: '\00b7';
    margin-right: 0.5rem;
    color: var(--color-foreground-lighten-60);
  }

  .card-variants__tag {
    background: rgb(var(--color-secondary-background));
    padding: 0.1rem 0.5rem;
    border-radius: 0.1875rem;
  }

  .card-variants__tag + span::before { content: none; }
  .card-variants__tag::before { content: none !important; }
  .card-variants__meta > .guest-only-content::before { content: none !important; }

  .card-variants__variant-name {
    color: var(--color-foreground-lighten-40);
  }
  .card-variants__variant-count {
    color: var(--color-foreground-lighten-40);
  }

  .card-variants__stock-summary.in-stock { color: #0d8756; }
  .card-variants__stock-summary.out-of-stock { color: #d97706; }

  .card-variants__outlet-badge {
    background: rgb(196, 48, 28);
    color: #fff;
    padding: 0.15rem 0.5rem;
    border-radius: 0.3125rem;
    font-weight: 500;
    font-size: 0.75em;
    line-height: 1.4;
  }

  .card-variants__outlet-badge::before { content: none !important; }

  .card-variants__outlet-tag {
    background: rgba(196, 48, 28, 0.1);
    color: rgb(var(--color-primary));
    padding: 0.05rem 0.375rem;
    border-radius: 0.1875rem;
    font-size: 0.7em;
    font-weight: 600;
    margin-left: 0.375rem;
    vertical-align: middle;
  }

  .card-variants__row--outlet .card-variants__price-value {
    color: rgb(var(--color-primary)) !important;
  }

  .card-variants__from-price-wrap--outlet .card-variants__from-value {
    color: rgb(var(--color-primary));
  }

  /* From-price: same width as table price column */
  .card-variants__from-price-wrap {
    flex: 0 0 var(--cv-col-price);
    box-sizing: border-box;
    display: flex;
    align-items: baseline;
    justify-content: flex-end;
    gap: 0.375rem;
    white-space: nowrap;
    padding-right: var(--cv-pad);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .card-variants__from-price-wrap.is-loaded { opacity: 1; }

  .card-variants__from-label { color: var(--color-foreground-lighten-40); }

  .card-variants__from-value {
    font-weight: 600;
    font-size: calc(var(--font-pcard-title-size, 1.1rem) * 1.3);
    color: rgb(var(--color-foreground));
  }

  .card-variants__from-unit { color: var(--color-foreground-lighten-40); }

  .card-variants__actions {
    display: flex;
    align-items: center;
    gap: var(--cv-col-gap);
    margin-left: auto;
  }

  /* Toggle: same width as table actions column */
  .card-variants__toggle {
    flex: 0 0 var(--cv-col-actions);
    text-transform: none !important;
    white-space: nowrap;
    box-sizing: border-box !important;
    justify-content: center;
  }

  .card-variants__toggle .btn__text {
    overflow: visible !important;
    text-overflow: unset !important;
  }

  .card-variants__toggle[aria-expanded="true"] .card-variants__toggle-icon {
    transform: rotate(180deg);
  }

  .card-variants__toggle-icon { transition: transform 0.2s; display: flex; align-items: center; }

  /* ========== Table ========== */
  .card-variants__table-wrapper {
    border-top: none;
    overflow: visible;
  }

  .card-variants__table-wrapper[hidden] { display: none; }

  .card-variants__table {
    width: 100%;
    border-collapse: collapse;
  }

  .card-variants__table thead th {
    text-align: left;
    padding: 0.75rem var(--cv-pad);
    font-weight: 600;
    font-size: 0.875rem !important;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #fff;
    background-color: rgb(var(--color-foreground));
    border-bottom: none;
    white-space: nowrap;
    vertical-align: middle;
  }

  .card-variants__table tbody td {
    padding: 0.75rem var(--cv-pad);
    vertical-align: middle;
    white-space: nowrap;
  }

  /* Column widths — shared variables keep header and table in sync */
  .card-variants__table td.card-variants__artno,
  .card-variants__table th:first-child {
    width: var(--cv-col-artno);
  }

  .card-variants__stock,
  .card-variants__table th:nth-last-child(3) {
    width: var(--cv-col-stock);
    min-width: var(--cv-col-stock);
    max-width: var(--cv-col-stock);
  }

  .card-variants__th-price,
  .card-variants__table td.card-variants__price {
    width: var(--cv-col-price);
    text-align: right !important;
    white-space: nowrap;
  }

  .card-variants__th-buy,
  .card-variants__table td.card-variants__buy-cell {
    width: var(--cv-col-actions);
    text-align: right;
    white-space: nowrap;
  }

  .card-variants__table td.card-variants__price.f-price {
    display: table-cell !important;
  }
  .card-variants__table td.card-variants__price.f-price.customer-only-table-cell:not(.is-visible) {
    display: none !important;
  }

  /* Row dividers */
  .card-variants__row {
    transition: background-color 0.1s;
    position: relative;
  }

  .card-variants__row::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 2px;
    right: 2px;
    height: 1px;
    background: rgb(var(--color-border));
  }

  .card-variants__row:last-child::after { display: none; }
  .card-variants__row:hover { background-color: rgba(var(--color-button), 0.05); }

  /* Art.nr link */
  .card-variants__artno { font-family: var(--font-body-family, monospace); }
  .card-variants__artno a { color: var(--color-foreground-lighten-40); text-decoration: none; }
  .card-variants__artno a:hover { text-decoration: underline; color: rgb(var(--color-foreground)); }

  .card-variants__option a { color: inherit; text-decoration: none; }
  .card-variants__option a:hover { text-decoration: underline; }

  /* ========== Stock ========== */
  .stock-dot {
    display: inline-block;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    margin-right: 0.625rem;
    vertical-align: middle;
    position: relative;
    top: -0.1em;
  }

  .stock-dot--in-stock { background-color: #0d8756; }
  .stock-dot--out-of-stock { background-color: #d97706; }
  .stock-dot--loading { background-color: #ccc; animation: stock-pulse 1s ease-in-out infinite; }

  @keyframes stock-pulse { 0%, 100% { opacity: 0.4; } 50% { opacity: 1; } }

  .card-variants__stock-wrap { position: relative; cursor: default; display: inline-block; }

  .card-variants__stock-tooltip {
    display: none;
    position: absolute;
    bottom: calc(100% + 0.5rem);
    left: 50%;
    transform: translateX(-50%);
    background: #fff;
    color: var(--status-color, #0d8756);
    line-height: 1.8;
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    white-space: nowrap;
    z-index: 10;
    box-shadow: 0 0.25rem 1rem rgba(0,0,0,0.12);
    pointer-events: none;
    border: 1px solid rgb(var(--color-border));
  }

  .card-variants__stock-tooltip::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 0.375rem solid transparent;
    border-top-color: #fff;
  }

  .card-variants__stock-wrap:hover .card-variants__stock-tooltip { display: block; }
  .card-variants__stock-tooltip .stock-dot { display: inline-block; width: 0.4rem; height: 0.4rem; vertical-align: middle; top: 0; position: static; }

  /* ========== Price ========== */
  .card-variants__price { font-weight: 600; }
  .card-variants__price-unit { color: var(--color-foreground-lighten-40); margin-left: 0.25rem; font-weight: 400; }
  .card-variants__price .card-variants__price-value { transition: opacity 0.3s ease; }
  .card-variants__price.f-price--loading .card-variants__price-value { opacity: 0; }
  .card-variants__price.f-price--loaded .card-variants__price-value { opacity: 1; }

  /* ========== Buy cell ========== */
  .card-variants__buy-cell { white-space: nowrap; }

  .card-variants__form {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
  }

  .card-variants__form .quantity {
    --buttons-height: var(--cv-btn-height);
    width: 8rem !important;
    max-width: 8rem !important;
  }

  .card-variants__form .quantity .quantity__input {
    font-size: 1rem !important;
    width: 3rem !important;
    padding: 0 !important;
    text-align: center;
  }

  .card-variants__form .quantity .quantity__button {
    width: 2rem !important;
    padding: 0 !important;
  }
  .card-variants__form .quantity .quantity__button[name="minus"] {
    left: 0.25rem !important;
  }
  .card-variants__form .quantity .quantity__button[name="plus"] {
    right: 0.25rem !important;
  }

  .card-variants__form .quantity .quantity__button svg {
    width: 14px;
    height: 14px;
  }

  .card-variants__add-btn {
    height: var(--cv-btn-height) !important;
    min-height: unset !important;
    padding: 0 1.5rem !important;
    margin-left: 0.375rem;
    text-transform: none !important;
    font-size: 1rem;
  }

  .card-variants__add-btn:hover {
    color: rgb(var(--color-button-text)) !important;
    background: rgb(var(--color-button)) !important;
    opacity: 0.85;
  }

  .card-variants__add-btn::before {
    display: none !important;
  }

  .card-variants__add-btn[disabled] {
    opacity: 0.35;
    cursor: not-allowed;
    pointer-events: none;
  }

  /* ========== Tablet ========== */
  @media (max-width: 1023px) {
    .card-variants__table-wrapper {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
  }

  /* ========== Mobile ========== */
  @media (max-width: 749px) {
    .card-variants {
      --cv-img-h: 56px;
      --cv-btn-height: 2.8rem;
      --cv-pad: 1.25rem;
    }

    .card-variants__title {
      font-size: 16px !important;
    }

    .card-variants__header {
      flex-wrap: wrap;
      padding: var(--cv-pad);
      gap: 0.75rem;
    }

    .card-variants__header {
      display: grid;
      grid-template-columns: auto 1fr auto;
      grid-template-rows: auto auto;
      gap: 0 calc(var(--cv-col-gap) * 1.5);
      align-items: start;
    }

    .card-variants__image {
      grid-row: 1;
      grid-column: 1;
    }

    .card-variants__info {
      grid-row: 1;
      grid-column: 2;
      padding: 0;
    }

    .card-variants__actions {
      display: contents;
    }

    .card-variants__from-price-wrap {
      grid-row: 1;
      grid-column: 3;
      flex: none !important;
      padding-right: 0;
      justify-content: flex-end;
    }

    .card-variants__from-price-wrap .card-variants__from-value {
